{
  "profile": "telegram-agent",
  "description": "Example only. Replace with your local OpenClaw configuration.",
  "telegram": {
    "enabled": true,
    "tokenEnv": "TELEGRAM_BOT_TOKEN"
  },
  "llm": {
    "provider": "openrouter",
    "baseUrlEnv": "OPENROUTER_BASE_URL",
    "apiKeyEnv": "OPENROUTER_API_KEY",
    "defaultModelEnv": "DEFAULT_MODEL"
  },
  "security": {
    "commitRealConfig": false,
    "storeSecretsInEnv": true
  }
}

